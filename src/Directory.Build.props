<Project>
  <PropertyGroup>
    <RepositoryRoot>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..'))</RepositoryRoot>
    <RepositoryReadme>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)../README.md'))</RepositoryReadme>
    <ImplicitUsings>disable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
    <IsPackable>true</IsPackable>
    <Authors>Tyrone Vergil</Authors>
    <Company>Tyrone Vergil</Company>
    <Product>CrudDatastore</Product>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/tyronevergil/CrudDatastore</RepositoryUrl>
    <PackageProjectUrl>https://github.com/tyronevergil/CrudDatastore</PackageProjectUrl>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <PackageTags>orm;crud;repository;unit-of-work;specification</PackageTags>
    <Description>CrudDatastore ORM library.</Description>
    <Version>2.0.0-preview</Version>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="$(RepositoryReadme)" Pack="true" PackagePath="\" Link="README.md" />
  </ItemGroup>
</Project>